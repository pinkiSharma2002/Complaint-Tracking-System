<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd"
         version="3.1">

    <display-name>Complaint Tracking System</display-name>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- User Servlets -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.complaint.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.complaint.servlet.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.complaint.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SubmitComplaintServlet</servlet-name>
        <servlet-class>com.complaint.servlet.user.SubmitComplaintServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SubmitComplaintServlet</servlet-name>
        <url-pattern>/user/submit</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>MyComplaintsServlet</servlet-name>
        <servlet-class>com.complaint.servlet.user.MyComplaintsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MyComplaintsServlet</servlet-name>
        <url-pattern>/user/mycomplaints</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ViewComplaintServlet</servlet-name>
        <servlet-class>com.complaint.servlet.user.ViewComplaintServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ViewComplaintServlet</servlet-name>
        <url-pattern>/user/view</url-pattern>
    </servlet-mapping>

    <!-- Admin Servlets -->
    <servlet>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <servlet-class>com.complaint.servlet.admin.AdminDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <url-pattern>/admin/dashboard</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminUpdateServlet</servlet-name>
        <servlet-class>com.complaint.servlet.admin.AdminUpdateServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminUpdateServlet</servlet-name>
        <url-pattern>/admin/update</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminViewServlet</servlet-name>
        <servlet-class>com.complaint.servlet.admin.AdminViewServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminViewServlet</servlet-name>
        <url-pattern>/admin/view</url-pattern>
    </servlet-mapping>

</web-app>
